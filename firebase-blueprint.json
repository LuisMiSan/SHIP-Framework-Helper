{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": {
           "type": "object",
           "properties": {
              "temperature": { "type": "number" },
              "model": { "type": "string" }
           }
        }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A S.H.I.P. framework project",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner's UID" },
        "name": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "userProfile": { "$ref": "UserProfile" },
        "data": {
          "type": "array",
          "items": { "$ref": "StepData" }
        }
      },
      "required": ["uid", "name", "data"]
    },
    "UserProfile": {
        "title": "UserProfile",
        "description": "Project-specific client info",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "company": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" }
        }
    },
    "StepData": {
        "title": "StepData",
        "description": "Data for a single framework step",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "userInput": { "type": "string" },
            "aiResponse": { "type": "string" },
            "aiResponseHistory": { "type": "array", "items": { "type": "string" } }
        }
    },
    "Template": {
      "title": "Template",
      "description": "Reusable project template",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string", "description": "UID of the creator" },
        "data": { "type": "array", "items": { "$ref": "StepData" } }
      },
      "required": ["name", "data"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Storage for user projects"
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Shared or global templates"
    }
  }
}
